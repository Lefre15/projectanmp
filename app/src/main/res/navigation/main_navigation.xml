<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.projectanmp.view.LoginFragment"
        android:label="Login Screen"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/actionDashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.projectanmp.view.DashboardFragment"
        android:label="Dashboard Screen"
        tools:layout="@layout/fragment_dashboard" >
        <action
            android:id="@+id/actionNewHabitFragment"
            app:destination="@id/newHabitFragment" />
        <action
            android:id="@+id/actionDashboardFragmentToEditHabitFragment"
            app:destination="@id/editHabitFragment"/>

    </fragment>
    <fragment
        android:id="@+id/newHabitFragment"
        android:name="com.example.projectanmp.view.NewHabitFragment"
        android:label="New Habit Screen"
        tools:layout="@layout/fragment_new_habit" />

    <fragment
        android:id="@+id/editHabitFragment"
        android:name="com.example.projectanmp.view.EditHabitFragment"
        android:label="Edit Habit Screen"
        tools:layout="@layout/fragment_edit_habit">

        <argument
            android:name="habitId"
            app:argType="integer"/>

        <action
            android:id="@+id/actionEditHabitFragmentToDashboardFragment"
            app:destination="@id/dashboardFragment"/>

    </fragment>
</navigation>
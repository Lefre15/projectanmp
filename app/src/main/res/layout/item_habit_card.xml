<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="habit"
            type="com.example.projectanmp.model.Habit" />
        <variable
            name="listener"
            type="com.example.projectanmp.view.HabitListener" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <!-- Icon -->
            <ImageView
                android:id="@+id/ivHabitIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/baseline_water_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Nama Habit -->
            <TextView
                android:id="@+id/habitName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@{habit.name}"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/ivHabitIcon"
                app:layout_constraintEnd_toStartOf="@id/habitStatus"
                app:layout_constraintTop_toTopOf="@id/ivHabitIcon"
                app:layout_constraintBottom_toBottomOf="@id/ivHabitIcon" />

            <!-- Status Label -->
            <TextView
                android:id="@+id/habitStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="#FF9800"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Deskripsi -->
            <TextView
                android:id="@+id/habitDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@{habit.description}"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                app:layout_constraintStart_toEndOf="@id/ivHabitIcon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/habitName" />

            <!-- Divider -->
            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/habitDescription"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Label Progress -->
            <TextView
                android:id="@+id/progressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progress"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider" />

            <!-- Progress Count -->
            <TextView
                android:id="@+id/progressCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 / 8 glasses"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:progress="@{habit.progress != null ? habit.progress : 0}"
                android:max="@{habit.goal != null ? habit.goal : 1}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressLabel" />

            <!-- Tombol - -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDecrement"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="20sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:onClick="@{() -> listener.onDecrement(habit)}"
                app:cornerRadius="18dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toStartOf="@id/btnIncrement"
                app:layout_constraintTop_toBottomOf="@id/progressBar" />

            <!-- Tombol + -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIncrement"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="20sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:onClick="@{() -> listener.onIncrement(habit)}"
                app:cornerRadius="18dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressBar" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>